# Starknet RPC endpoint
STARKNET_RPC_URL=http://ip:port/rpc/v0_10

# Funded account address on the test network
STARKNET_ACCOUNT_ADDRESS=0x...

# Private key for the account (KEEP SECRET)
STARKNET_PRIVATE_KEY=0x...

# Chain ID (default: SN_INTEGRATION_SEPOLIA)
# STARKNET_CHAIN_ID=SN_INTEGRATION_SEPOLIA

# Privacy gateway URL (default: https://privacy-starknet-integration.starknet.io)
# STARKNET_GATEWAY_URL=https://privacy-starknet-integration.starknet.io

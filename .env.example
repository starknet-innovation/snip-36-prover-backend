# Starknet RPC endpoint
STARKNET_RPC_URL=http://ip:port/rpc/v0_10

# Funded account address on the test network
STARKNET_ACCOUNT_ADDRESS=0x...

# Private key for the account (KEEP SECRET)
STARKNET_PRIVATE_KEY=0x...

# Sequencer gateway URL for proof submission (bypasses RPC node)
# Required: RPC nodes (pathfinder) don't yet support compressed proofs
STARKNET_GATEWAY_URL=https://alpha-sepolia.starknet.io

# Chain ID (default: SN_SEPOLIA)
# STARKNET_CHAIN_ID=SN_SEPOLIA
